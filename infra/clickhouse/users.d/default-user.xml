<clickhouse>
  <!-- Docs: <https://clickhouse.com/docs/operations/settings/settings_users/> -->
  <users>
    <!-- Remove default user -->
    <default remove="remove">
    </default>

    <log_user>
      <profile>default</profile>
      <networks>
        <ip>172.16.0.0/12</ip>
        <ip>10.0.0.0/8</ip>
        <ip>127.0.0.1</ip>
      </networks>
      <password><![CDATA[${CLICKHOUSE_PASSWORD}]]></password>
      <quota>default</quota>
    </log_user>
  </users>
</clickhouse>
