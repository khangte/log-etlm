<clickhouse>
  <users>
    <grafana_user>
      <profile>default</profile>
      <networks>
        <ip>::/0</ip>
      </networks>
      <password from_env="CLICKHOUSE_GRAFANA_PASSWORD"/>
      <quota>default</quota>
      <settings>
        <max_memory_usage>1073741824</max_memory_usage>
        <max_bytes_before_external_group_by>805306368</max_bytes_before_external_group_by>
        <max_bytes_before_external_sort>536870912</max_bytes_before_external_sort>
        <max_threads>4</max_threads>
        <priority>10</priority>
        <max_execution_time>8</max_execution_time>
        <readonly>1</readonly>
      </settings>
    </grafana_user>
  </users>
</clickhouse>
