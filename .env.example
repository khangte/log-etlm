# =============================================================================
# log-etlm 환경 변수 예시
# 복사 후 .env 로 저장하고 각 값을 실제 값으로 교체하세요.
#   cp .env.example .env
# .env 는 .gitignore 에 포함되어 있어 커밋되지 않습니다.
# =============================================================================

# -----------------------------------------------------------------------------
# ClickHouse 인증
# log_user (Spark 적재용), grafana_user (Grafana 읽기 전용) 에서 사용
# -----------------------------------------------------------------------------
CLICKHOUSE_PASSWORD=change_me_log_user_password
CLICKHOUSE_GRAFANA_PASSWORD=change_me_grafana_user_password
GRAFANA_ADMIN_PASSWORD=change_me_grafana_admin_password

# -----------------------------------------------------------------------------
# Spark ClickHouse sink 튜닝 (선택 — 기본값 있음)
# -----------------------------------------------------------------------------
SPARK_CLICKHOUSE_JDBC_BATCHSIZE=10000
SPARK_CLICKHOUSE_WRITE_PARTITIONS=3
SPARK_CLICKHOUSE_ALLOW_REPARTITION=false
SPARK_SKIP_EMPTY_BATCH=false
