# MID: 5~7k EPS (4s trigger 기준)
# --- Kafka ingest ---
SPARK_ENV_PROFILE=mid
SPARK_MAX_OFFSETS_PER_TRIGGER=
SPARK_MAX_OFFSETS_SAFETY=1.1
SPARK_MAX_OFFSETS_CAP=50000
SPARK_KAFKA_MIN_PARTITIONS_MULTIPLIER=1
# --- 트리거 / Spark 자원 ---
SPARK_FACT_TRIGGER_INTERVAL=4 seconds
SPARK_STREAM_SHUFFLE_PARTITIONS=8
# --- Transform / Write ---
SPARK_FACT_PRE_COALESCE_PARTITIONS=2
SPARK_CLICKHOUSE_WRITE_PARTITIONS=2
SPARK_CLICKHOUSE_JDBC_BATCHSIZE=15000
SPARK_CLICKHOUSE_ALLOW_REPARTITION=false
